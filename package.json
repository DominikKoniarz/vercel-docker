{
    "name": "vercel-docker",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun --watch index.ts",
        "compile": "bun build index.ts --compile --outfile dist/server",
        "deploy": "vercel deploy",
        "deploy:prod": "vercel deploy --prod",
        "docker:build": "docker build -f Dockerfile.vercel -t vercel-docker .",
        "docker:run": "docker run --rm --init -p 3000:3000 vercel-docker "
    },
    "devDependencies": {
        "@types/bun": "latest"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
